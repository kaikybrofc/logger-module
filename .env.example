# --- Configurações de Ambiente ---
# Ambiente da Aplicação (development, production, test)
NODE_ENV=development

# --- Configurações de Logger ---
# Nível mínimo de log
# Opções: fatal, emerg, alert, crit, error, warn, notice, info, success, http, verbose, debug, silly
LOG_LEVEL=debug

# Formato de saída no console
# pretty: colorido e amigável para humanos (padrão em dev)
# json: objeto estruturado para agregadores de log (padrão em prod)
LOG_FORMAT=pretty

# Nome do serviço para identificação nos logs
ECOSYSTEM_NAME=logger-module-api

# --- Segurança e Redação ---
# Caminho para arquivo opcional (.json, .csv ou .txt) com chaves sensíveis extras para mascaramento
# LOG_SENSITIVE_FILE=./custom-sensitive-keys.txt

# --- Automação de Release (npm run release) ---
# Tokens necessários para o fluxo de release automático
GITHUB_TOKEN=seu_token_aqui
NPM_TOKEN=seu_token_aqui

# --- Configurações de Instância (Opcionais - detectadas automaticamente no PM2) ---
# PM2_INSTANCE_ID=0
# NODE_APP_INSTANCE=0
