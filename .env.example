# --- Configurações de Ambiente ---
NODE_ENV=development

# --- Configurações de Logger ---
# Opções: fatal, security, audit, emerg, alert, crit, error, warn, notice, info, success, http, verbose, debug, silly
LOG_LEVEL=debug

# Formato do console: pretty (dev) ou json (prod)
LOG_FORMAT=pretty

# Nome do serviço nos logs
ECOSYSTEM_NAME=logger-module-api

# --- Controle de Tráfego (Sampling & Rate Limit) ---
# Taxa global de amostragem (0.0 a 1.0). 1.0 significa 100% dos logs.
LOG_SAMPLING_RATE=1.0

# Máximo de logs permitidos por janela para uma mesma chave (Prevenção de Flood)
LOG_RATE_LIMIT_MAX=100

# Janela de tempo em milissegundos para o rate limit (Padrão: 60000 = 1 minuto)
LOG_RATE_LIMIT_WINDOW_MS=60000

# --- Níveis Dinâmicos ---
# Adicione novos métodos ao logger ex: LOG_EXTRA_LEVELS="trace:15,webhook:16"
LOG_EXTRA_LEVELS=

# --- Segurança e Redação ---
# Arquivo opcional (.json, .csv ou .txt) com chaves sensíveis extras para mascarar
# LOG_SENSITIVE_FILE=./custom-sensitive-keys.csv

# --- Exportação Opcional (Requer instalação manual da biblioteca correspondente) ---
# Host do Grafana Loki (Requer: winston-loki)
# LOKI_HOST=http://localhost:3100

# Node do Elasticsearch (Requer: winston-elasticsearch)
# ELASTICSEARCH_NODE=http://localhost:9200

# API Key do Datadog (Requer: datadog-winston)
# DATADOG_API_KEY=your-api-key

# --- Auditoria Imutável (Chain-of-Trust) ---
# Ativa gravação em logs/auditoria.log com hashing SHA-256 encadeado (true/false)
LOG_AUDIT_IMMUTABLE=false

# --- Automação de Release ---
GITHUB_TOKEN=
NPM_TOKEN=
